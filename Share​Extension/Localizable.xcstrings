    "image.altHint" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALT-Text hilft Menschen, die Bilder nicht sehen können, deren Inhalt zu verstehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALT text helps people who can't see images understand what they show."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El texto ALT ayuda a las personas que no pueden ver imágenes a entender su contenido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le texte ALT aide les personnes qui ne peuvent pas voir les images à comprendre leur contenu."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teks ALT membantu orang yang tidak dapat melihat gambar memahami isinya."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALTテキストは、画像を見られない人がその内容を理解するのに役立ちます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALT 텍스트는 이미지를 볼 수 없는 사람들이 내용을 이해하는 데 도움이 됩니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O texto ALT ajuda pessoas que não podem ver imagens a entender o conteúdo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALT-текст помогает людям, которые не видят изображения, понять их содержание."
          }
        },
        "zh-CN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALT 文本可帮助无法查看图片的人了解图片内容。"
          }
        },
        "zh-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ALT 文字可幫助無法查看圖片的人了解圖片內容。"
          }
        }
      }
    },
