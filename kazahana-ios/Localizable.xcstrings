    "iap.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 Tage gültig. Während der Gültigkeitsdauer erscheint ein Medaillenicon auf Ihrem Profilavatar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Active for 30 days. A medal icon appears on your profile avatar while the badge is active."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válido 30 días. Aparece un icono de medalla en tu avatar de perfil mientras el distintivo esté activo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valable 30 jours. Une icône de médaille apparaît sur votre avatar de profil pendant la durée de validité du badge."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berlaku selama 30 hari. Ikon medali muncul di avatar profil Anda selama lencana aktif."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "購入は30日間有効です。有効期間中はプロフィール画面のアバターに勲章が表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30일 동안 유효합니다. 배지가 활성화된 동안 프로필 아바타에 메달 아이콘이 표시됩니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Válido por 30 dias. Um ícone de medalha aparece no seu avatar de perfil enquanto o distintivo estiver ativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Активен 30 дней. Значок медали отображается на аватаре профиля пока значок активен."
          }
        },
        "zh-CN" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有效期30天。徽章有效期间，个人资料头像上会显示勋章图标。"
          }
        },
        "zh-TW" : {
